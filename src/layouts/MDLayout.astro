---
import "../styles/global.css";
const { frontmatter = {} } = Astro.props;
const pageTitle = frontmatter.title;

const pathName = new URL(Astro.request.url).pathname;
const currentPath = pathName.split('/').filter(Boolean)[0]
---

<!DOCTYPE html>
<html lang="en">  
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class:list={{active: currentPath === "undefined"}}>Home</a>
        <a href="/about" class:list={{active: currentPath === "about"}}>About</a> 
        <a href="/blog" class:list={{active: currentPath === "blog"}}>Blog</a>
      </nav>
      <a href="/posts" class:list={{active: currentPath === "posts"}}>API</a>
    </header>
    <slot />
  </body>
</html>